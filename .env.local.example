# ============================================================
# 파일명: .env.local.example
# 경로:   cafe-bot-dashboard/.env.local.example
# 역할:   환경변수 예시 파일 — 실제 사용 시 .env.local 로 복사
#
# 사용 방법:
#   cp .env.local.example .env.local
#   → .env.local 파일에 실제 값 입력
#   → .env.local 은 절대 GitHub 커밋 금지 (.gitignore에 포함됨)
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Supabase 프로젝트 설정 → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://cvvurdxdxfayijmmzcwt.supabase.co

# Supabase 프로젝트 설정 → API → anon public 키 (읽기 전용 대시보드용)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── GitHub Actions API ────────────────────────────────────────
# GitHub → Settings → Developer settings → Personal access tokens
# 권한: repo (workflow 트리거용)
GITHUB_TOKEN=your_github_pat_here

# GitHub 레포 정보 (봇 ON/OFF 트리거용)
GITHUB_OWNER=kangyh427
GITHUB_REPO=naver_cafe_bot
GITHUB_WORKFLOW_ID=main.yml
